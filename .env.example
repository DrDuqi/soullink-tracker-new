# Supabase connection — required for the app to work.
# Local dev: copy this file to ".env" and fill in the values.
# Production (Vercel): set these as Environment Variables in the Project Settings.
#
# Both values are safe to expose in the client bundle: the anon key is a public
# key and all data access is protected by Row Level Security policies.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
